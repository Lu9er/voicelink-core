SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
GCS_BUCKET_NAME=your-bucket-name
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/gcp-key.json

# Module 2: Twilio credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Module 2: Cloud Tasks (production — omit for local BackgroundTasks fallback)
CLOUD_TASKS_QUEUE_PATH=projects/your-project/locations/us-central1/queues/voicelink
WORKER_BASE_URL=https://voicelink-xxxxx.run.app
CLOUD_TASKS_SERVICE_ACCOUNT=worker@your-project.iam.gserviceaccount.com

# Module 3: Audio Processor tunables (all optional — defaults shown)
# CLIP_MP3_BITRATE_KBPS=64
# CLIP_MIN_SECONDS=3
# CLIP_MAX_SECONDS=15
# VAD_MERGE_GAP_SECONDS=0.5
# SPEECH_YIELD_GATE=0.01
# DRY_RUN=false

# Module 4: Transcription
# TRANSCRIBE_BACKEND=faster_whisper
# WHISPER_MODEL_SIZE=base
# OPENAI_API_KEY=sk-...              (only if using openai_whisper backend)

# Module 4: Common Voice submission
# CV_API_BASE_URL=https://commonvoice.mozilla.org/api/v1
# CV_AUTH_EMAIL=you@example.com
# CV_AUTH_PASSWORD=secret
# CV_LANGUAGE=ate
# CV_RESOURCE_TYPE=spontaneous
