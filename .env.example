SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
GCS_BUCKET_NAME=your-bucket-name
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/gcp-key.json

# Module 2: Twilio credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Module 2: Cloud Tasks (production — omit for local BackgroundTasks fallback)
CLOUD_TASKS_QUEUE_PATH=projects/your-project/locations/us-central1/queues/voicelink
WORKER_BASE_URL=https://voicelink-xxxxx.run.app
CLOUD_TASKS_SERVICE_ACCOUNT=worker@your-project.iam.gserviceaccount.com

# Module 3: Whisper transcription
OPENAI_API_KEY=sk-your-openai-api-key
